# Build artifacts (Rust + Go + macOS .app bundles)
target/
**/target/
*.app/
mautrix-imessage
mautrix-imessage-v2
bbctl
librustpushgo.a
extract-key
tools/extract-key/extract-key
.build-commit

# rustpush-upstream is cloned by `make ensure-rustpush-source` inside the
# Dockerfile builder. Excluding it here keeps the build context small and
# guarantees we use the pinned SHA, not whatever happens to be on disk.
third_party/rustpush-upstream/

# Packaged Swift apps — not needed in the bridge image.
tools/extract-key-app/*.zip
tools/extract-key-app/.build/
tools/nac-relay-app/*.zip
tools/nac-relay-app/.build/

# IDE / editor / OS noise
.DS_Store
.vscode/
.idea/
*.swp
*~

# Repository state we don't need at build time. We DO keep `.git/` because
# the Makefile uses `git rev-parse --short HEAD` to embed the commit into
# the binary version stamp. If we excluded .git the version would read
# "unknown" — keep it.
.github/
.claude/

# Project tracking — not consumed by the build.
_todo/

# Documentation that lives in docs/ is also not needed at build time;
# keep .dockerignore minimal here in case the build ever pulls README
# metadata. Comment-out by default.
# docs/
# README.md
