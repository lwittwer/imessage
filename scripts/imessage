#!/usr/bin/env bash
# ============================================================================
# imessage — host-side CLI for the mautrix-imessage-v2 Docker bridge.
#
# Install once (one line, always on PATH):
#   curl -L https://raw.githubusercontent.com/lrhodin/imessage/master/scripts/imessage \
#     | sudo install /dev/stdin /usr/local/bin/imessage
#
# To update later: re-run the same command.
# To uninstall:    sudo rm /usr/local/bin/imessage
#
# All subcommands work from any directory. Compose-driven subcommands
# (start / stop / restart / update / pull) need to know where your
# docker-compose.yml lives — set IMESSAGE_COMPOSE_FILE, or run from the
# directory containing it.
# ============================================================================
set -euo pipefail

CONTAINER="${IMESSAGE_CONTAINER:-Rustpush-Matrix}"
COMPOSE_FILE="${IMESSAGE_COMPOSE_FILE:-}"

# Marker block format matches the bare-Linux install scripts so migrating
# in either direction never produces duplicates. Keep this string in sync
# with scripts/install-beeper-linux.sh and scripts/install-linux.sh.
MARKER_START="# >>> mautrix-imessage shortcuts (managed) >>>"
MARKER_END="# <<< mautrix-imessage shortcuts (managed) <<<"

usage() {
    cat <<'EOF'
imessage — host-side CLI for the mautrix-imessage-v2 Docker bridge.

USAGE
    imessage <command> [args...]

Every subcommand is a thin wrapper around the raw command shown after the
arrow. Useful when debugging or when you want to run the underlying
operation manually.

DAILY (work from any directory — container looked up by name)
    setup           → docker exec -it Rustpush-Matrix imessage-setup
                      Interactive setup wizard inside the container.
    login           → docker exec -it Rustpush-Matrix /entrypoint.sh login
                      Re-run only the iMessage login flow.
    logs            → tail -F <host bind-mount>/logs/bridge.log
                      Live-watch the bridge's full zerolog file directly
                      on the host volume. Works whether the container
                      is running, restart-looping, or stopped — the
                      file persists on the bind mount regardless.
    status          → docker ps --filter name=^Rustpush-Matrix$
                      Is the container running?
    shell           → docker exec -it Rustpush-Matrix bash
                      Open a debug shell inside the container.
    bbctl <args>    → docker exec -it Rustpush-Matrix bbctl <args>
                      Run the Beeper bridge-manager CLI inside the container.
                      e.g. `imessage bbctl whoami`, `imessage bbctl logout`.

LIFECYCLE (must run from the directory with docker-compose.yml — or set IMESSAGE_COMPOSE_FILE)
    start           → docker compose up -d
    stop            → docker compose stop Rustpush-Matrix
    restart         → docker compose restart Rustpush-Matrix
    pull            → docker compose pull
    update          → docker compose pull && docker compose up -d
    fix-perms       Read the bind mount + user: from your compose file
                    and chown the host data dir to match. Run before
                    'imessage start' (especially on first install — the
                    bridge can't open /data until its host owner matches
                    the UID compose declares).

ONE-TIME (host-side only — no docker calls)
    migrate         Migrate from a bare-Linux install:
                      • strip the bare-Linux managed-alias block from
                        ~/.bashrc / ~/.zshrc
                      • stop + disable + remove the mautrix-imessage
                        systemd unit (user + system scopes)
                      • rewrite absolute paths in config.yaml to /data
                      • leave state at ~/.local/share/mautrix-imessage
                        in place
                    Then run `imessage fix-perms`, `imessage start`,
                    and `imessage setup`.

OTHER
    help, -h, --help    Print this message.

ENV
    IMESSAGE_CONTAINER      Container name (default: Rustpush-Matrix).
    IMESSAGE_COMPOSE_FILE   Path to docker-compose.yml for lifecycle commands.
                            Otherwise compose looks in the current dir.

Examples
    imessage setup
    imessage logs
    imessage bbctl whoami
    IMESSAGE_COMPOSE_FILE=~/docker/imessage/docker-compose.yml imessage update
EOF
}

# ── helpers ─────────────────────────────────────────────────────────────────

# compose() — invoke docker compose with the user's compose file if set.
compose() {
    if [ -n "$COMPOSE_FILE" ]; then
        docker compose -f "$COMPOSE_FILE" "$@"
    else
        docker compose "$@"
    fi
}

# detect_rc_files() — print paths to host shell rc files that exist.
# Same heuristic the bare-Linux installer uses (case "$SHELL"), but we
# return all matching files because users may have both.
detect_rc_files() {
    local files=()
    case "${SHELL:-}" in
        */zsh)  [ -f "$HOME/.zshrc" ] && files+=("$HOME/.zshrc") ;;
        */bash) [ -f "$HOME/.bashrc" ] && files+=("$HOME/.bashrc") ;;
        *)
            # Unknown shell — fall back to whichever rc files exist.
            [ -f "$HOME/.bashrc" ] && files+=("$HOME/.bashrc")
            [ -f "$HOME/.zshrc" ] && files+=("$HOME/.zshrc")
            ;;
    esac
    printf '%s\n' "${files[@]}"
}

# strip_marker_block <rc-file>
# Safe to re-run: returns 0 if anything was stripped, 1 otherwise.
strip_marker_block() {
    local rc="$1"
    if [ -f "$rc" ] && grep -qF "$MARKER_START" "$rc"; then
        awk -v s="$MARKER_START" -v e="$MARKER_END" '
            $0 == s { skip = 1; next }
            $0 == e { skip = 0; next }
            !skip   { print }
        ' "$rc" > "$rc.tmp" && mv "$rc.tmp" "$rc"
        return 0
    fi
    return 1
}

# ── commands ────────────────────────────────────────────────────────────────

cmd_setup()   { exec docker exec -it "$CONTAINER" imessage-setup "$@"; }
cmd_login()   { exec docker exec -it "$CONTAINER" /entrypoint.sh login "$@"; }
cmd_logs()    {
    # Live-tail the bridge's zerolog file directly on the host volume.
    # We do this without `docker exec` so it keeps working even when the
    # container is restart-looping, stopped, or otherwise unhealthy —
    # the bind-mounted file persists regardless of container state.
    #
    # The host path is discovered by inspecting the container's /data
    # mount, so it follows whatever the user put in compose (default
    # ~/.local/share/mautrix-imessage, UNRAID /mnt/user/appdata/...,
    # Synology /volume1/docker/..., anything).
    local host_path
    host_path=$(docker inspect --format '{{range .Mounts}}{{if eq .Destination "/data"}}{{.Source}}{{end}}{{end}}' "$CONTAINER" 2>/dev/null || true)
    if [ -z "$host_path" ]; then
        echo "error: container '$CONTAINER' doesn't exist or has no /data mount." >&2
        echo "  Did you 'imessage start' yet?" >&2
        exit 1
    fi
    exec tail -F "$host_path/logs/bridge.log"
}
cmd_shell()   { exec docker exec -it "$CONTAINER" bash; }
cmd_status()  { docker ps --filter "name=^${CONTAINER}$" --format 'table {{.Names}}\t{{.Status}}\t{{.Image}}'; }
cmd_bbctl()   { exec docker exec -it "$CONTAINER" bbctl "$@"; }

cmd_fix_perms() {
    # Read the bind-mount source and target UID:GID directly from the
    # compose file (NOT from a running container — fix-perms has to work
    # before the first `imessage start`). Same compose-dir rule as
    # start/stop/restart: must run from the directory with your
    # docker-compose.yml or set IMESSAGE_COMPOSE_FILE.
    if [ ! -t 0 ] || [ ! -t 1 ]; then
        echo "error: fix-perms is interactive; run from a real terminal." >&2
        exit 2
    fi

    # Verify we can render the compose file from here.
    if ! compose config --format json >/dev/null 2>&1; then
        cat >&2 <<EOF
error: docker compose can't render a compose file from here.

fix-perms reads the bind mount + user from your compose project —
same CWD rule as 'imessage start'. cd to the directory containing
docker-compose.yml, or set IMESSAGE_COMPOSE_FILE to its absolute path.
EOF
        exit 1
    fi

    if ! command -v python3 >/dev/null 2>&1; then
        echo "error: python3 is required to parse the compose file." >&2
        echo "  Install it: apt install python3   (or your distro's equivalent)" >&2
        exit 1
    fi

    # Pull the /data bind source and the container user out of the
    # rendered compose JSON. Service name defaults to Rustpush-Matrix;
    # falls back to the first service if the user renamed it.
    local parsed
    parsed=$(compose config --format json | python3 -c '
import sys, json
cfg = json.load(sys.stdin)
services = cfg.get("services", {})
svc = services.get("Rustpush-Matrix") or next(iter(services.values()), {})
src = ""
for v in svc.get("volumes", []) or []:
    if isinstance(v, dict) and v.get("target") == "/data":
        src = v.get("source", "")
        break
user = svc.get("user") or "1000:1000"
user = str(user)
if ":" not in user:
    user = f"{user}:{user}"
print(src)
print(user)
') || { echo "error: failed to parse compose config" >&2; exit 1; }

    local bind_source user_dir
    bind_source=$(printf '%s\n' "$parsed" | sed -n '1p')
    user_dir=$(printf '%s\n' "$parsed" | sed -n '2p')

    if [ -z "$bind_source" ]; then
        echo "error: no bind mount with target '/data' found in compose." >&2
        echo "  Make sure your docker-compose.yml has a volumes: entry like" >&2
        echo "  '- ~/.local/share/mautrix-imessage:/data'." >&2
        exit 1
    fi

    if ! printf '%s' "$user_dir" | grep -qE '^[0-9]+:[0-9]+$'; then
        echo "error: 'user: $user_dir' in compose isn't numeric UID:GID." >&2
        echo "  Edit docker-compose.yml's 'user:' line to a numeric form like \"1000:1000\"." >&2
        exit 1
    fi

    if [ ! -d "$bind_source" ]; then
        echo "Note: '$bind_source' doesn't exist yet — will create it."
        if [ "$(id -u)" = "0" ]; then
            mkdir -p "$bind_source"
        else
            sudo mkdir -p "$bind_source"
        fi
    fi

    echo ""
    echo "Read from your compose project:"
    echo "    bind mount    : $bind_source → /data"
    echo "    container user: $user_dir"
    echo ""
    echo "About to run:"
    if [ "$(id -u)" = "0" ]; then
        echo "    chown -R $user_dir $bind_source"
    else
        echo "    sudo chown -R $user_dir $bind_source"
    fi
    local yn
    read -r -p "Proceed? [y/N]: " yn
    case "$yn" in
        [yY]|[yY][eE][sS]) ;;
        *) echo "Aborted."; exit 0 ;;
    esac

    if [ "$(id -u)" = "0" ]; then
        chown -R "$user_dir" "$bind_source"
    else
        sudo chown -R "$user_dir" "$bind_source"
    fi
    echo "✓ Done. You can now run 'imessage start' (or 'imessage restart' if already up)."
}

cmd_start()   { compose up -d; }
cmd_stop()    { compose stop "$CONTAINER"; }
cmd_restart() { compose restart "$CONTAINER"; }
cmd_pull()    { compose pull; }
cmd_update()  { compose pull && compose up -d; }

cmd_migrate() {
    echo "═══════════════════════════════════════════════"
    echo "  mautrix-imessage → Docker migration (host)"
    echo "═══════════════════════════════════════════════"
    echo ""

    # 1. Strip bare-Linux systemd-based shell aliases — they shell out to
    #    `systemctl ... mautrix-imessage` and will no longer work.
    local stripped=0
    while IFS= read -r rc; do
        [ -z "$rc" ] && continue
        if strip_marker_block "$rc"; then
            echo "✓ Removed managed-alias block from $rc"
            stripped=1
        fi
    done < <(detect_rc_files)
    [ "$stripped" -eq 0 ] && echo "✓ No managed-alias block found — nothing to strip from rc files."
    echo ""

    # 2. Stop + disable + remove the systemd unit.
    local touched=0
    if systemctl --user list-unit-files mautrix-imessage.service 2>/dev/null | grep -q mautrix-imessage; then
        echo "Stopping + disabling systemd --user unit..."
        systemctl --user stop mautrix-imessage 2>/dev/null || true
        systemctl --user disable mautrix-imessage 2>/dev/null || true
        rm -f "$HOME/.config/systemd/user/mautrix-imessage.service"
        systemctl --user daemon-reload 2>/dev/null || true
        echo "✓ systemd --user unit removed."
        touched=1
    fi
    if systemctl list-unit-files mautrix-imessage.service 2>/dev/null | grep -q mautrix-imessage; then
        echo "Stopping + disabling systemd system unit (sudo)..."
        sudo systemctl stop mautrix-imessage 2>/dev/null || true
        sudo systemctl disable mautrix-imessage 2>/dev/null || true
        sudo rm -f /etc/systemd/system/mautrix-imessage.service
        sudo systemctl daemon-reload 2>/dev/null || true
        echo "✓ systemd system unit removed."
        touched=1
    fi
    [ "$touched" -eq 0 ] && echo "✓ No systemd unit found — nothing to tear down."
    echo ""

    # 3. Sanity-check the state dir.
    local config="$HOME/.local/share/mautrix-imessage/config.yaml"
    if [ -d "$HOME/.local/share/mautrix-imessage" ] && [ -f "$config" ]; then
        echo "✓ State at ~/.local/share/mautrix-imessage looks intact."

        # 3a. Rewrite the absolute database URI in config.yaml. The
        # bare-Linux install bakes the host appdata path into config
        # (e.g. file:/root/.local/share/mautrix-imessage/mautrix-imessage.db
        # or file:/home/<user>/...). Inside the container that path
        # doesn't exist — the bind mount lives at /data — and SQLite
        # comes back with "permission denied" on open. Normalize any
        # absolute file:/sqlite: URI ending in mautrix-imessage.db to
        # the container's /data path.
        if grep -qE '(uri: (file|sqlite):/.+/mautrix-imessage\.db)' "$config"; then
            sed -i -E 's|uri: file:/.+/mautrix-imessage\.db|uri: file:/data/mautrix-imessage.db|' "$config"
            sed -i -E 's|uri: sqlite:/.+/mautrix-imessage\.db|uri: sqlite:/data/mautrix-imessage.db|' "$config"
            echo "✓ Rewrote database URI in config.yaml to /data/mautrix-imessage.db"
        fi
    else
        echo "⚠  State directory missing or empty. The bridge will run setup as a fresh install."
    fi
    echo ""

    cat <<'EOF'
Next:
  1. Make sure your docker-compose.yml points at the existing state path
     (~/.local/share/mautrix-imessage:/data by default in the example).
  2. imessage start
  3. The bridge should resume with no re-login. If you flip toggles or
     re-login later: imessage setup.
EOF
}

# ── dispatch ────────────────────────────────────────────────────────────────

cmd="${1:-}"
[ -n "$cmd" ] && shift || true

case "$cmd" in
    setup)              cmd_setup "$@" ;;
    login)              cmd_login "$@" ;;
    logs)               cmd_logs "$@" ;;
    shell)              cmd_shell "$@" ;;
    status)             cmd_status "$@" ;;
    bbctl)              cmd_bbctl "$@" ;;
    start)              cmd_start "$@" ;;
    stop)               cmd_stop "$@" ;;
    restart)            cmd_restart "$@" ;;
    pull)               cmd_pull "$@" ;;
    update)             cmd_update "$@" ;;
    migrate)            cmd_migrate "$@" ;;
    fix-perms)          cmd_fix_perms "$@" ;;
    ""|help|-h|--help)  usage ;;
    *)                  echo "error: unknown command '$cmd'" >&2; usage >&2; exit 2 ;;
esac
