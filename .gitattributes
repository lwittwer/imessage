# Normalize all text files to LF in the repository and check them out as LF
# on every platform. This prevents Windows editors from introducing CRLF
# phantom diffs (which also strip the +x bit off shell scripts on round-trip).
* text=auto eol=lf

# Shell scripts and Go must be LF or they break at runtime / fail builds.
*.sh   text eol=lf
*.bash text eol=lf
*.go   text eol=lf
*.rs   text eol=lf

# Known binary assets — never apply EOL conversion or diff as text.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.icns binary
*.zip  binary
*.gz   binary
*.a    binary
*.so   binary
*.dylib binary
*.dll  binary
*.p12  binary
*.plist binary
